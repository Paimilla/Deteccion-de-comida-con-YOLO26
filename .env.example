# ═══════════════════════════════════════════════════════════════════════════════
# Nutrifoto AI — Variables de Entorno (Template)
# ═══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env o usa --dart-define para pasar las variables.
#
# Ejemplo de uso:
#   flutter run \
#     --dart-define=GEMINI_API_KEY=tu_clave_aqui \
#     --dart-define=EDAMAM_APP_ID=tu_app_id \
#     --dart-define=EDAMAM_APP_KEY=tu_app_key
# ═══════════════════════════════════════════════════════════════════════════════

# Google Gemini (IA / NLP) — https://ai.google.dev/
GEMINI_API_KEY=

# Groq (IA / NLP - Backup) — https://console.groq.com/
GROQ_API_KEY=

# USDA FoodData Central — https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# Spoonacular (Recetas) — https://spoonacular.com/food-api
SPOONACULAR_API_KEY=

# LibreTranslate (opcional) — https://libretranslate.com/
LIBRETRANSLATE_API_KEY=

# Webhook de registro (opcional) — Google Apps Script / Discord / Slack
REGISTRATION_WEBHOOK_URL=
